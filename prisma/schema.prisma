// 9jacodekids Academy Enrollment Management System - Prisma Schema
// Optimized for PostgreSQL with indexing for 1000s of students

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ==================== Users (Authentication) ====================
model User {
  id            String   @id @default(cuid())
  email         String   @unique
  password      String   // Hashed with bcrypt
  firstName     String
  lastName      String
  role          UserRole @default(STAFF)
  isActive      Boolean  @default(true)
  tokenVersion  Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  sentInvitations UserInvitation[] @relation("UserInvitations")
  requestedPasswordResets PasswordResetToken[] @relation("PasswordResetRequests")
  passwordResetTokens PasswordResetToken[] @relation("UserPasswordResetTokens")

  @@index([email])
}

enum UserRole {
  SUPERADMIN
  ADMIN
  STAFF
}

model UserInvitation {
  id          String           @id @default(cuid())
  email       String
  firstName   String
  lastName    String
  role        UserRole
  tokenHash   String           @unique
  status      InvitationStatus @default(PENDING)
  invitedById String
  invitedBy   User             @relation("UserInvitations", fields: [invitedById], references: [id], onDelete: Cascade)
  expiresAt   DateTime
  acceptedAt  DateTime?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  @@index([email])
  @@index([status])
  @@index([expiresAt])
  @@index([invitedById])
}

enum InvitationStatus {
  PENDING
  ACCEPTED
  REVOKED
  EXPIRED
}

model PasswordResetToken {
  id            String    @id @default(cuid())
  userId        String
  user          User      @relation("UserPasswordResetTokens", fields: [userId], references: [id], onDelete: Cascade)
  requestedById String
  requestedBy   User      @relation("PasswordResetRequests", fields: [requestedById], references: [id], onDelete: Cascade)
  tokenHash     String    @unique
  expiresAt     DateTime
  usedAt        DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([userId])
  @@index([requestedById])
  @@index([expiresAt])
  @@index([usedAt])
}

// ==================== Teachers ====================
model Teacher {
  id                String   @id @default(cuid())
  firstName         String
  lastName          String
  email             String   @unique
  phone             String
  bio               String?
  profilePhoto      String?
  status            TeacherStatus @default(ACTIVE)
  qualifiedCourses  String[] // Array of course IDs
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  // Relations
  classes           Class[]

  @@index([email])
  @@index([status])
}

enum TeacherStatus {
  ACTIVE
  INACTIVE
  ON_LEAVE
}

// ==================== Courses ====================
model Course {
  id                String   @id @default(cuid())
  name              String   @unique
  description       String?
  programLevels     String[] // Stable program level codes
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  // Relations
  classes           Class[]

  @@index([name])
}

model ProgramLevelSetting {
  id                String       @id @default(cuid())
  level             String       @unique
  displayName       String
  ageRange          String?
  description       String?
  sortOrder         Int          @default(0)
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt

  @@index([sortOrder])
}

// ==================== Programs ====================
model Program {
  id                String   @id @default(cuid())
  name              String
  type              ProgramType
  season            Season
  year              Int
  batches           Int
  slots             String[] // Time slots for this program
  startDate         DateTime // Start date of the program
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  // Relations
  classes           Class[]
  enrollments       ProgramEnrollment[]

  @@unique([name, season, year])
  @@index([season])
  @@index([year])
}

enum ProgramType {
  WEEKEND_CLUB
  HOLIDAY_CAMP
}

enum Season {
  JANUARY
  EASTER
  MAY
  SUMMER
  OCTOBER
}

// ==================== Families ====================
model Family {
  id                String   @id @default(cuid())
  displayName       String
  isArchived        Boolean  @default(false)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  guardians         ParentGuardian[]
  students          Student[]

  @@index([displayName])
  @@index([isArchived])
}

model ParentGuardian {
  id                String   @id @default(cuid())
  familyId          String
  firstName         String
  lastName          String
  email             String?
  emailNormalized   String?
  phone             String?
  phoneNormalized   String?
  phoneCountryCode  String?
  relationship      GuardianRelationship @default(PARENT)
  isPrimary         Boolean  @default(false)
  isActive          Boolean  @default(true)
  needsReview       Boolean  @default(false)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  family            Family   @relation(fields: [familyId], references: [id], onDelete: Cascade)

  @@index([familyId])
  @@index([emailNormalized])
  @@index([phoneNormalized, phoneCountryCode])
  @@index([isPrimary])
  @@index([isActive])
  @@index([needsReview])
}

enum GuardianRelationship {
  PARENT
  MOTHER
  FATHER
  GUARDIAN
  OTHER
}

// ==================== Classes ====================
model Class {
  id                String   @id @default(cuid())
  name              String
  courseId          String
  programId         String
  programLevel      String
  batch             Int
  slot              String
  schedule          String
  capacity          Int
  students          String[] // Array of student IDs
  teacherId         String?
  meetLink          String?  // Google Meet link for this class
  isArchived        Boolean  @default(false)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  // Relations
  course            Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  program           Program  @relation(fields: [programId], references: [id], onDelete: Cascade)
  teacher           Teacher? @relation(fields: [teacherId], references: [id], onDelete: SetNull)
  enrollments       ProgramEnrollment[]

  @@unique([name])
  @@index([programId])
  @@index([courseId])
  @@index([teacherId])
  @@index([isArchived])
}

// ==================== Students ====================
model Student {
  id                String   @id @default(cuid())
  firstName         String
  lastName          String
  email             String?   @unique
  phone             String?   @unique
  phoneCountryCode  String?   // Country code for student phone (e.g., 'NG', 'US')
  dateOfBirth       DateTime?
  isReturningStudent Boolean  @default(false)
  paymentStatus     PaymentStatus @default(PENDING)
  familyId          String?
  parentEmail       String?
  parentPhone       String?
  parentPhoneCountryCode String? // Country code for parent phone
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  // Relations
  family            Family?  @relation(fields: [familyId], references: [id], onDelete: SetNull)
  enrollments       ProgramEnrollment[]
  courseHistory     CourseHistory[]

  @@index([familyId])
  @@index([email])
  @@index([phone])
  @@index([parentEmail])
  @@index([parentPhone])
  @@index([isReturningStudent])
  @@index([dateOfBirth])
}

// ==================== Program Enrollments ====================
model ProgramEnrollment {
  id                String   @id @default(cuid())
  studentId         String
  programId         String
  classId           String?  // Null for waitlist
  batchNumber       Int      @default(1)
  enrollmentDate    DateTime @default(now())
  status            EnrollmentStatus
  paymentStatus     PaymentStatus @default(PENDING)
  priceType         PriceType @default(FULL_PRICE)
  priceAmount       Int      @default(60000)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  // Relations
  student           Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  program           Program  @relation(fields: [programId], references: [id], onDelete: Cascade)
  class             Class?   @relation(fields: [classId], references: [id], onDelete: SetNull)

  // Indexes - No unique constraint on (studentId, classId) since we allow multiple NULL classIds
  // A student can have multiple ASSIGNED or WAITLIST enrollments (waiting for class assignment)
  @@index([studentId])
  @@index([programId])
  @@index([classId])
  @@index([status])
}

enum EnrollmentStatus {
  WAITLIST
  ASSIGNED
  COMPLETED
  DROPPED
}

enum PaymentStatus {
  PENDING
  CONFIRMED
  COMPLETED
}

enum PriceType {
  FULL_PRICE
  SIBLING_DISCOUNT
  EARLY_BIRD
}

// ==================== Email Logs ====================
model EmailLog {
  id                String         @id @default(cuid())
  eventType         EmailEventType
  status            EmailLogStatus @default(QUEUED)
  recipientEmail    String
  recipientName     String?
  recipientRole     String?
  subject           String?
  provider          String         @default("resend")
  providerMessageId String?
  error             String?
  studentId         String?
  classId           String?
  enrollmentId      String?
  triggeredById     String?
  payload           Json?
  sentAt            DateTime?
  deliveredAt       DateTime?
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt

  @@index([eventType])
  @@index([status])
  @@index([recipientEmail])
  @@index([providerMessageId])
  @@index([studentId])
  @@index([classId])
  @@index([enrollmentId])
  @@index([createdAt])
}

enum EmailEventType {
  CLASS_ASSIGNMENT
  TEACHER_ASSIGNMENT
  USER_INVITATION
  PASSWORD_RESET
}

enum EmailLogStatus {
  QUEUED
  SENT
  FAILED
  DELIVERED
  BOUNCED
}

// ==================== Pricing Configuration ====================
model PricingConfig {
  id                String   @id @default(cuid())
  priceType         PriceType @unique
  amount            Int
  updatedBy         String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([priceType])
}

// ==================== Course History ====================
model CourseHistory {
  id                String   @id @default(cuid())
  studentId         String
  courseId          String
  courseName        String
  programId         String?
  programName       String?
  batch             Int      @default(1)
  year              Int?
  completionStatus  CompletionStatus
  startDate         DateTime?
  endDate           DateTime?
  performanceNotes  String?
  dateAdded         DateTime @default(now())
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  // Relations
  student           Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@index([studentId])
  @@index([completionStatus])
  @@index([dateAdded])
}

enum CompletionStatus {
  IN_PROGRESS
  COMPLETED
}
