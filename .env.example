# Database Configuration
# For local development with PostgreSQL, copy this to .env and update values
# For production on Coolify, set the environment variable in Coolify settings.

# Example PostgreSQL connection string
# Format: postgresql://user:password@host:port/database
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/academy_enrollment"

# Node environment
NODE_ENV="development"

# JWT Secret used by the app login session token.
# Generate one per environment with: openssl rand -base64 32
JWT_SECRET="your-jwt-secret-here"

# Database initialization behavior for container startup.
# Use "migrate" for Coolify staging/production, "push" only for disposable local databases, or "skip".
DB_INIT_MODE="migrate"

# Keep false in production unless you explicitly want to load test/default data.
RUN_DATABASE_SEED="false"

# Used only when RUN_DATABASE_SEED=true. Override in staging if desired.
SEED_ADMIN_EMAIL="admin@9jacodekids.com"
SEED_ADMIN_PASSWORD="Admin@123"

# Keep false in production so bad migrations fail the deploy instead of starting a broken app.
ALLOW_START_WITH_DB_INIT_FAILURE="false"

# ========== Email Configuration ==========
# Transactional email provider for class assignment notifications.
# Supported values: "resend" or "disabled".
EMAIL_PROVIDER="resend"

# Resend API key. Create this in Resend and add it as a secret in Coolify.
RESEND_API_KEY="re_xxxxxxxxxxxxxxxxxxxxxxxxx"

# Sender identity must be verified in Resend.
EMAIL_FROM="9jacodekids Academy <classes@yourdomain.com>"

# Optional reply-to address for parents and tutors.
EMAIL_REPLY_TO="admin@9jacodekids.com"

# ========== Paid Registration Imports ==========
# WordPress helper endpoint that returns paid registration form submissions for preview/import.
# If omitted, the app falls back to WORDPRESS_BASE_URL + /wp-json/9ck/v1/confirmed-registrations/search.
WORDPRESS_CONFIRMED_REGISTRATIONS_ENDPOINT="https://example.com/wp-json/9ck/v1/confirmed-registrations/search"
WORDPRESS_BASE_URL="https://example.com"
WORDPRESS_API_USER="wordpress-api-user"
WORDPRESS_API_PASSWORD="wordpress-application-password"

# Persistent Coolify volume path for uploaded payment proof files.
PAYMENT_PROOF_STORAGE_DIR="/app/storage/payment-proofs"

# Optional endpoint on WordPress that applies FluentCRM paid tags.
FLUENTCRM_SYNC_ENDPOINT="https://example.com/wp-json/9ck/v1/fluentcrm/sync-paid-customer"
FLUENTCRM_SYNC_SECRET="shared-secret-for-sync-endpoint"

# ========== Google Meet Configuration ==========
# Google Cloud Project credentials for Meet API (will be added after setting up Google Cloud)
# GOOGLE_MEET_API_KEY="your-api-key"
# GOOGLE_MEET_PROJECT_ID="your-project-id"
