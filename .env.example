# Database Configuration
# For local development with PostgreSQL, copy this to .env and update values
# For production on Coolify, set the environment variable in Coolify settings.

# Example PostgreSQL connection string
# Format: postgresql://user:password@host:port/database
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/academy_enrollment"

# Node environment
NODE_ENV="development"

# JWT Secret used by the app login session token.
# Generate one per environment with: openssl rand -base64 32
JWT_SECRET="your-jwt-secret-here"

# Database initialization behavior for container startup.
# Use "migrate" for Coolify staging/production, "push" only for disposable local databases, or "skip".
DB_INIT_MODE="migrate"

# Keep false in production unless you explicitly want to load test/default data.
RUN_DATABASE_SEED="false"

# Used only when RUN_DATABASE_SEED=true. Override in staging if desired.
SEED_ADMIN_EMAIL="admin@9jacodekids.com"
SEED_ADMIN_PASSWORD="Admin@123"

# Keep false in production so bad migrations fail the deploy instead of starting a broken app.
ALLOW_START_WITH_DB_INIT_FAILURE="false"

# ========== AWS SES Configuration ==========
# Amazon SES credentials for sending emails
AWS_ACCESS_KEY_ID="your-aws-access-key-id"
AWS_SECRET_ACCESS_KEY="your-aws-secret-access-key"
AWS_REGION="us-east-1"

# Email configuration
# The email address that emails will be sent from (must be verified in AWS SES)
AWS_SES_FROM_EMAIL="noreply@9jacodekids.com"

# ========== Google Meet Configuration ==========
# Google Cloud Project credentials for Meet API (will be added after setting up Google Cloud)
# GOOGLE_MEET_API_KEY="your-api-key"
# GOOGLE_MEET_PROJECT_ID="your-project-id"
